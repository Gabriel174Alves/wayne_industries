# Wayne Industries Environment Configuration
# Copy this file to `.env` and configure with your production secrets

# =============================================================================
# PRODUCTION CONFIGURATION (REQUIRED)
# =============================================================================

# JWT Secret Key - GENERATE ONE FOR PRODUCTION
# Command: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<GENERATE_32+_CHAR_SECURE_SECRET_HERE>

# Flask Environment
FLASK_ENV=production

# Additional Secret Key for Flask
SECRET_KEY=<GENERATE_ADDITIONAL_SECRET_HERE>

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite Local Database (Recommended for simplicity)
DATABASE_URL=sqlite:///armory.db

# Alternative: Turso/libSQL Cloud Database (Optional)
# DATABASE_URL=libsql://your-db-url.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# =============================================================================
# OPTIONAL CONFIGURATIONS
# =============================================================================

# External API Keys (Optional - not required for core functionality)
# SUPERHERO_API_KEY=your-superhero-api-key

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# For development, you can use these values:
# FLASK_ENV=development
# JWT_SECRET_KEY=wayne-jwt-secret-2024-dev-only
# SECRET_KEY=wayne-industries-secret-key-2024-dev

# =============================================================================
# SECURITY NOTES
# =============================================================================

# 1. NEVER commit real secrets to version control
# 2. Always use different secrets for production vs development
# 3. JWT_SECRET_KEY must be at least 32 characters long
# 4. Change default passwords after first login (batman/wayne123)
# 5. Use HTTPS in production environments

# =============================================================================
# EXAMPLE PRODUCTION SECRETS (DO NOT USE - GENERATE YOUR OWN)
# =============================================================================

# JWT_SECRET_KEY=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz-secure-key
# SECRET_KEY=wayne-industries-production-secret-key-2024-very-secure
