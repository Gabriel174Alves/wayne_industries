# Example environment variables for backend (do NOT commit secrets)
# Copy this file to `.env` and fill real secrets in your local environment.
DATABASE_URL=libsql://<your-db-host>
SUPERHERO_API_KEY=<your-superhero-api-key>
TURSO_AUTH_TOKEN=<your-turso-auth-token>
JWT_SECRET_KEY=<replace-with-32+ char secret>
FLASK_ENV=development
# Example environment variables for the backend
# For local development (SQLite fallback):
# DATABASE_URL can be left empty to use the default local SQLite file `armory.db`.

# Use one of the following formats depending on your provider.
# Turso / libSQL example:
# DATABASE_URL=libsql://armory-gabriel174alves.aws-us-east-2.turso.io

# Postgres example (Supabase/Neon):
# DATABASE_URL=postgres://user:password@host:5432/armory

# SQLite local example (relative path):
# DATABASE_URL=sqlite:///./armory.db

# JWT secret
JWT_SECRET_KEY=change-me-to-a-strong-secret

# Flask environment (optional)
FLASK_ENV=development

# Generate a secure JWT secret (example):
# Run this locally and copy the output into your .env or CI secret store
# python -c "import secrets; print(secrets.token_urlsafe(48))"

# Recommended: use a secret at least 32 characters long.
SECRET_KEY=wayne-industries-secret-key-2024
FLASK_ENV=development
DATABASE_URL=sqlite:///armory.db
SUPERHERO_API_KEY=1
JWT_SECRET_KEY=wayne-jwt-secret-2024
